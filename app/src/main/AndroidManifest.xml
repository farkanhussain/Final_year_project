<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="Taffakur Therapy"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Therapy_app"
        android:enableOnBackInvokedCallback="true">

        <!-- SplashActivity opens first -->
        <activity
            android:name=".SplashActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- Login screen -->
        <activity
            android:name=".LoginActivity"
            android:exported="true" />

        <!-- Main screen -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />
        <activity android:name=".RegisterActivity" />
        <activity android:name=".MFAEnrollmentActivity"/>
        <activity android:name=".MfaSignInActivity"/>
        <activity android:name=".ProfileActivity"/>
        <activity android:name=".SettingsActivity"/>
        <activity android:name=".TherapyActivity"/>
        <activity android:name=".MoodTrackingActivity"/>
        <activity android:name=".JournalingActivity"/>
        <activity android:name=".ArticlesActivity"/>
        <activity android:name=".ChatActivity"/>



    </application>

</manifest>
