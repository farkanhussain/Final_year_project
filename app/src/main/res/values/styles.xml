<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="NavDrawerTextStyle" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textSize">40dp</item>
        <item name="itemIconSize">40dp</item>
        <item name="itemHorizontalPadding">20dp</item>
        <item name="itemVerticalPadding">12dp</item>
    </style>

    <!-- Chip Style -->
    <style name="TagChipStyle" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipBackgroundColor">@color/red_dark</item>
        <item name="android:textColor">@color/white</item>
        <item name="chipStrokeColor">@color/red_dark</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="checkedIconVisible">false</item>
    </style>

    <style name="TherapyHintAppearance" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/hint_colors</item>
    </style>


</resources>

