<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/beige">

    <!-- Blurred Blob Background -->
    <ImageView
        android:id="@+id/blur_blob"
        android:layout_width="311dp"
        android:layout_height="288dp"
        android:layout_marginTop="40dp"
        android:src="@drawable/blur_blob"
        android:alpha="1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.216" />

    <!-- Logo -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="500dp"
        android:layout_height="500dp"
        android:alpha="0"
        android:contentDescription="App Logo"
        android:src="@drawable/logo"
        app:layout_constraintTop_toTopOf="@id/blur_blob"
        app:layout_constraintBottom_toBottomOf="@id/blur_blob"
        app:layout_constraintStart_toStartOf="@id/blur_blob"
        app:layout_constraintEnd_toEndOf="@id/blur_blob" />

    <!-- Loading Spinner -->
    <ProgressBar
        android:id="@+id/loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Disclaimer Card at Bottom -->
    <androidx.cardview.widget.CardView
        android:id="@+id/disclaimer_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:padding="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/loading"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/disclaimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This app uses an AI chatbot which may make mistakes. Please use traditional services for urgent cases."
            android:textAlignment="center"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp" />
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>

